{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",

  "properties": {
	
	"bookingid":{
		
		"type":"integer"
	},
   
    "firstname": {
      "type": "string"
    },
	
	"lastname": {
	     "type": "string"
	   },

    "totalprice": {
      "type": "integer"
    },

    "depositpaid": {
      "type": "boolean"
    },

    "bookingdates": {
      "type": "object"{
		
		"checkin":{
			"type":"string"
			
			},
	   "checkout":{
		
		"type":"string"
	
		},	
			
	}
    },
	
	"additionalneeds":{
		
		"type":"string"
	}
  },

  "required": [
	"bookingid",
    "firstname",
    "lastname",
    "totalprice",
    "depositpaid",
    "bookingdates",
	"checkin",
	"checkout",
	"additionalneeds"
  ]
}